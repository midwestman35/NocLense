{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@shared/types": ["../src/types.ts"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "../src/types.ts"]
}
