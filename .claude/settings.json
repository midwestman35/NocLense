{
  "project": "noclense",
  "docsRoot": "docs",
  "defaultModel": "codex",
  "codeReview": {
    "requireTestsForBehaviorChanges": true,
    "focus": ["regressions", "performance", "security"]
  },
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Read",
      "Glob",
      "Grep"
    ]
  }
}
