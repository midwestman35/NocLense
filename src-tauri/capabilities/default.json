{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-open",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-stat",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$DESKTOP/**/*"
        },
        {
          "path": "$DOCUMENT/**/*"
        },
        {
          "path": "$DOWNLOAD/**/*"
        },
        {
          "path": "$HOME/**/*"
        },
        {
          "path": "$PUBLIC/**/*"
        },
        {
          "path": "$TEMP/**/*"
        }
      ]
    },
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        {
          "url": "https://e-api.unleash.so/**"
        },
        {
          "url": "https://**.zendesk.com/**"
        },
        {
          "url": "https://**.datadoghq.com/**"
        },
        {
          "url": "https://**.datadoghq.eu/**"
        },
        {
          "url": "https://**.atlassian.net/**"
        }
      ]
    }
  ]
}
